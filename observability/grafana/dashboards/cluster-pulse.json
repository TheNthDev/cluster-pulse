      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "cluster_pulse_node_count",
          "legendFormat": "Total Nodes",
          "refId": "A"
        },
        {
          "expr": "cluster_pulse_node_unreachable",
          "legendFormat": "Unreachable",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Entity & Shard Count Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "cluster_pulse_entity_count",
          "legendFormat": "Entities",
          "refId": "A"
        },
        {
          "expr": "cluster_pulse_shard_count",
          "legendFormat": "Shards",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Health Score Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "cluster_pulse_health_score",
          "legendFormat": "Health",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Per-Node Entity Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
