        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "cluster_pulse_node_entity_count",
          "legendFormat": "{{node_address}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Per-Node Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 30 },
          "mappings": [
            { "options": { "0": { "text": "Unreachable" }, "1": { "text": "Up" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "cluster_pulse_node_status",
          "legendFormat": "{{node_address}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Node Count Delta",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -1 },
              { "color": "green", "value": 0 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "cluster_pulse_node_count_delta",
          "legendFormat": "Node Delta",
          "refId": "A"
        }
      ]
    },
